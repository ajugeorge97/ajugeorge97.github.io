---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import SectionHeading from "../../components/SectionHeading.astro";

const posts = (await getCollection("blog")).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Blog | Aju George">
  <section class="section-shell py-20">
    <SectionHeading eyebrow="Blog" title="Insights from the research-systems boundary." />
    <div class="grid gap-5">
      {posts.map((post) => (
        <a class="story-card rounded-lg p-6 transition hover:border-cyan/40" href={`/blog/${post.slug}/`}>
          <p class="text-sm text-slate-400">{post.data.date.toLocaleDateString("en", { month: "long", day: "numeric", year: "numeric" })}</p>
          <h2 class="mt-3 font-display text-2xl font-bold text-white">{post.data.title}</h2>
          <p class="mt-3 leading-7 text-slate-300">{post.data.description}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
