---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import SectionHeading from "../../components/SectionHeading.astro";

const publications = await getCollection("publications");
---

<BaseLayout title="Research & Publications | Aju George">
  <section class="section-shell py-20">
    <SectionHeading eyebrow="Research" title="Synthetic imaging, evaluation, and translational ML." description="Publication-style entries and research summaries centered on deep generative models for breast MRI." />
    <div class="grid gap-5">
      {publications.map((publication) => (
        <article class="story-card rounded-lg p-6">
          <p class="text-sm font-semibold text-cyan">{publication.data.venue} / {publication.data.year}</p>
          <h2 class="mt-3 font-display text-2xl font-bold text-white">{publication.data.title}</h2>
          <p class="mt-2 text-sm text-slate-400">{publication.data.authors}</p>
          <p class="mt-4 leading-7 text-slate-300">{publication.data.description}</p>
          <div class="mt-5 flex flex-wrap gap-2">
            {publication.data.tags.map((tag) => <span class="rounded-full border border-white/10 px-3 py-1 text-xs text-slate-300">{tag}</span>)}
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
