---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { BrainCircuit, CloudCog, Cpu, Database, Network, Workflow } from "lucide-react";

const experience = [
  {
    title: "PhD Researcher - Universitatsklinikum Erlangen",
    description:
      "Developing AI models for virtual contrast enhancement in breast MRI while building toward scalable Kubernetes-based ML workflows."
  },
  {
    title: "Student Assistant - Medical Image Data Systems",
    description:
      "Automated XNAT image data workflows, maintained metadata extraction for REDCap, tested research code, and built a 3D Slicer plugin."
  },
  {
    title: "CT / MRI Field Service Engineering",
    description:
      "Installed, maintained, and troubleshot CT and MRI systems across Philips, Cyrix Healthcare, and GE Healthcare channel partner roles."
  },
  {
    title: "Research Fellowship - IIT Madras",
    description:
      "Worked on deep learning for biomedical applications, including a machine learning GUI for cardiovascular risk prediction."
  }
];

const skills = [
  { label: "Deep Learning", Icon: BrainCircuit },
  { label: "Medical Imaging", Icon: Cpu },
  { label: "Kubernetes", Icon: CloudCog },
  { label: "XNAT / REDCap Workflows", Icon: Workflow },
  { label: "Testing Practices", Icon: Database },
  { label: "CT / MRI Systems", Icon: Network }
];
---

<BaseLayout title="Aju George | Medical AI + MLOps">
  <section class="section-shell grid min-h-[calc(100vh-64px)] items-center gap-12 py-20 lg:grid-cols-[1fr_0.82fr]">
    <div>
      <p class="mb-5 text-sm font-semibold uppercase tracking-[0.2em] text-cyan">Medical Deep Learning Researcher | Kubernetes / MLOps</p>
      <h1 class="font-display text-5xl font-extrabold leading-[1.02] text-white md:text-7xl">Aju George</h1>
      <p class="mt-6 max-w-2xl text-xl leading-9 text-slate-300">
        PhD Researcher and Kubernetes application developer at Universitatsklinikum Erlangen, with a Medical Engineering background from FAU Erlangen-Nurnberg.
      </p>
      <p class="mt-5 max-w-2xl leading-8 text-slate-400">
        I work on virtual contrast enhancement in breast MRI, medical image data workflows, and scalable systems for reliable AI research.
      </p>
      <div class="mt-9 flex flex-wrap gap-3">
        <a href="/timeline/" class="rounded-full bg-cyan px-5 py-3 text-sm font-bold text-ink transition hover:bg-white">My Journey</a>
        <a href="/projects/" class="rounded-full border border-white/15 px-5 py-3 text-sm font-bold text-white transition hover:border-white">Projects</a>
        <a href="/contact/" class="rounded-full border border-violet/45 px-5 py-3 text-sm font-bold text-violet transition hover:bg-violet/10">Contact</a>
      </div>
    </div>

    <div class="story-card reveal rounded-lg p-5">
      <div class="aspect-[4/5] overflow-hidden rounded-lg border border-white/10">
        <img
          src="https://images.unsplash.com/photo-1535713875002-d1d0cf377fde?auto=format&fit=crop&w=900&q=80"
          alt="Portrait placeholder for Aju George"
          class="h-full w-full object-cover opacity-90"
        />
      </div>
    </div>
  </section>

  <section class="section-shell py-16">
    <SectionHeading eyebrow="Experience" title="Research depth with platform instincts." />
    <div class="grid gap-5 md:grid-cols-2">
      {experience.map((item) => (
        <article class="story-card reveal rounded-lg p-6">
          <h2 class="font-display text-2xl font-bold text-white">{item.title}</h2>
          <p class="mt-4 leading-7 text-slate-300">{item.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section-shell py-16">
    <SectionHeading eyebrow="Skills" title="The tools I bring into the room." />
    <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
      {skills.map(({ label, Icon }) => (
        <div class="story-card reveal flex items-center gap-4 rounded-lg p-5">
          <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-cyan/15 text-cyan ring-1 ring-cyan/30">
            <Icon size={22} strokeWidth={1.8} />
          </div>
          <p class="font-semibold text-white">{label}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="section-shell py-24">
    <div class="story-card rounded-lg p-8 md:p-12">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-cyan">Contact</p>
      <h2 class="mt-4 max-w-3xl font-display text-3xl font-extrabold text-white md:text-5xl">
        Let's build medical AI that can be evaluated, trusted, and operated.
      </h2>
      <a href="/contact/" class="mt-8 inline-flex rounded-full bg-white px-5 py-3 text-sm font-bold text-ink transition hover:bg-cyan">
        Start a conversation
      </a>
    </div>
  </section>
</BaseLayout>
