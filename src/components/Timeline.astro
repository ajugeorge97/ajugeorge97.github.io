---
import TimelineProgress from "./TimelineProgress";

interface Milestone {
  id: string;
  data: {
    order: number;
    title: string;
    date: string;
    period: string;
    description: string;
    image: string;
    alt: string;
  };
}

interface Props {
  items: Milestone[];
  preview?: boolean;
}

const { items, preview = false } = Astro.props;
const milestones = [...items].sort((a, b) => a.data.order - b.data.order);
---

<div class="relative" data-timeline>
  <TimelineProgress client:load />
  <div class="absolute left-5 top-0 h-full w-px bg-white/12 md:left-1/2 md:-translate-x-1/2"></div>
  <div
    class="absolute left-5 top-0 w-px bg-gradient-to-b from-cyan via-violet to-cyan md:left-1/2 md:-translate-x-1/2"
    style="height: var(--timeline-progress);"
  >
  </div>

  <div class="space-y-10 md:space-y-16">
    {milestones.slice(0, preview ? 4 : milestones.length).map((milestone, index) => {
      const isEven = index % 2 === 0;
      return (
        <article class={`reveal relative grid gap-6 pl-14 md:grid-cols-[1fr_88px_1fr] md:items-center md:pl-0`}>
          <div class={`${isEven ? "md:col-start-1" : "md:col-start-3"} overflow-hidden rounded-lg border border-white/10 bg-white/[0.03]`}>
            <img
              src={milestone.data.image}
              alt={milestone.data.alt}
              loading="lazy"
              class="h-64 w-full object-cover opacity-85 transition duration-500 hover:scale-[1.03] hover:opacity-100"
            />
          </div>

          <div data-timeline-marker class="absolute left-5 top-7 h-4 w-4 -translate-x-1/2 rounded-full border border-cyan bg-ink shadow-[0_0_28px_rgba(45,212,191,0.55)] md:relative md:left-auto md:top-auto md:col-start-2 md:mx-auto md:translate-x-0">
            <span class="absolute left-7 top-1/2 -translate-y-1/2 whitespace-nowrap rounded-full border border-white/10 bg-ink/90 px-3 py-1 text-xs font-semibold text-cyan shadow-glow md:left-1/2 md:top-8 md:-translate-x-1/2 md:translate-y-0">
              {milestone.data.date}
            </span>
          </div>

          <div class={`${isEven ? "md:col-start-3" : "md:col-start-1 md:row-start-1 md:text-right"} story-card rounded-lg p-6`}>
            <p class="text-sm font-semibold uppercase tracking-[0.16em] text-violet">{milestone.data.period}</p>
            <h3 class="mt-3 font-display text-2xl font-bold text-white">{milestone.data.title}</h3>
            <p class="mt-3 leading-7 text-slate-300">{milestone.data.description}</p>
          </div>
        </article>
      );
    })}
  </div>
</div>
