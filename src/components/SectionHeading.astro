---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
}

const { eyebrow, title, description } = Astro.props;
---

<div class="mb-10 max-w-3xl">
  {eyebrow && <p class="mb-3 text-sm font-semibold uppercase tracking-[0.18em] text-cyan">{eyebrow}</p>}
  <h2 class="font-display text-3xl font-extrabold leading-tight text-white md:text-5xl">{title}</h2>
  {description && <p class="mt-4 text-lg leading-8 text-slate-300">{description}</p>}
</div>
