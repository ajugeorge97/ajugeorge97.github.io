---
interface Props {
  title: string;
  description: string;
  area: string;
  tags: string[];
  href: string;
}

const { title, description, area, tags, href } = Astro.props;
---

<a href={href} class="story-card group block rounded-lg p-6 transition duration-300 hover:-translate-y-1 hover:border-cyan/45">
  <p class="text-sm font-semibold text-cyan">{area}</p>
  <h3 class="mt-4 font-display text-2xl font-bold text-white">{title}</h3>
  <p class="mt-3 leading-7 text-slate-300">{description}</p>
  <div class="mt-6 flex flex-wrap gap-2">
    {tags.map((tag) => (
      <span class="rounded-full border border-white/10 bg-white/[0.04] px-3 py-1 text-xs font-medium text-slate-300">{tag}</span>
    ))}
  </div>
</a>
